{
    "build": {
        "builder": "NIXPACKS",
        "env": {
            "NODE_VERSION": "24"
        }
    },
    "deploy": {
        "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
        "rootDirectory": "backend_laravel",
        "healthCheckPath": "/",
        "restartPolicyType": "ON_FAILURE"
    }
}