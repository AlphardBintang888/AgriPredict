{
    "$schema": "https://railway.app/v2/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "env": {
            "NODE_VERSION": "20"
        }
    },
    "deploy": {
        "startCommand": "cd backend_laravel && php artisan serve --host=0.0.0.0 --port=$PORT",
        "rootDirectory": "./"
    }
}